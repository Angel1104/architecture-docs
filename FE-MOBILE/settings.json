{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "dart \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-spec-first.dart\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "dart \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-spec-first.dart\""
          }
        ]
      }
    ]
  }
}
